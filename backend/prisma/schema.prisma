// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  INVESTOR
  SHIPPING_COMPANY
}

// KYC verification status — sourced from Sumsub webhook events.
enum KycStatus {
  NOT_STARTED // no applicant created yet
  INIT // applicant created, verification not started
  PENDING // documents uploaded, awaiting review
  COMPLETED // verification passed (reviewAnswer = GREEN)
  REJECTED // verification failed / resubmission requested (reviewAnswer = RED)
  ON_HOLD // review paused
}

// KYB (business) verification status — sourced from Sumsub KYB webhook events.
// Only applies to SHIPPING_COMPANY users; investors never enter this lifecycle.
enum KybStatus {
  NOT_STARTED // no KYB applicant created yet
  INIT // applicant created, verification not started
  PENDING // company data + documents submitted, awaiting automated checks
  COMPLETED // automated registry + AML checks passed
  REJECTED // registry check failed or AML match found
  ON_HOLD // review paused (e.g. document re-upload requested)
}

// Investment profile answers collected before KYC verification.
// Each user has at most one profile (1:1). Answers are stored as JSON
// because the questionnaire structure is flexible (single + multi-select).
model User {
  id                String             @id @default(cuid())
  username          String             @unique
  email             String             @unique
  firstName         String?
  lastName          String?
  role              UserRole           @default(INVESTOR)
  dfnsUserId        String?            @unique
  userAuthToken     String?
  // SHA-256 hash of the currently-valid refresh token (rotation / revocation).
  refreshTokenHash  String?
  wallet            Wallet?
  signSession       SignSession[]
  investmentProfile InvestmentProfile?
  businessProfile   BusinessProfile?
  collateral        Collateral[]

  // --- KYC (Sumsub) ---
  // New users are NOT verified regardless of role. This is only set to
  // COMPLETED once Sumsub's applicantReviewed webhook confirms reviewAnswer
  // GREEN. Gates access to the full app until KYC is done.
  kycStatus            KycStatus @default(NOT_STARTED)
  sumsubApplicantId    String?   @unique
  sumsubExternalUserId String? // mirrors our user id for Sumsub lookups

  // --- KYB (Sumsub business verification) ---
  // Only SHIPPING_COMPANY users go through KYB. Shipping companies skip KYC
  // and go straight to KYB. KybStatus tracks the business verification
  // lifecycle independently from KYC. Must be COMPLETED for the shipping
  // company to tokenize RWAs.
  kybStatus               KybStatus @default(NOT_STARTED)
  sumsubKybApplicantId    String?   @unique
  sumsubKybExternalUserId String? // "{userId}:kyb" for webhook routing

  // Business profile data — populated from Sumsub KYB webhook when approved.
  companyName               String?
  companyRegistrationNumber String?
  companyCountry            String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([username])
  @@index([email])
  @@index([dfnsUserId])
  @@index([kycStatus])
  @@index([kybStatus])
}

model Wallet {
  id           String        @id @default(cuid())
  dfnsWalletId String        @unique
  address      String        @unique
  network      String
  name         String
  signingKeyId String?
  user         User          @relation(fields: [userId], references: [id])
  userId       String        @unique
  signSessions SignSession[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([address])
  @@index([dfnsWalletId])
  @@index([userId])
}

model SignSession {
  id             String  @id @default(cuid())
  message        String
  transactionXdr String
  status         String  @default("initiated")
  signedXdr      String?
  wallet         Wallet  @relation(fields: [walletId], references: [id])
  walletId       String
  user           User    @relation(fields: [userId], references: [id])
  userId         String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([walletId])
  @@index([userId])
  @@index([status])
}

// Investment profile answers collected before KYC verification.
// Each user has at most one profile (1:1). Answers are stored as JSON
// because the questionnaire structure is flexible (single + multi-select).
model InvestmentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  answers   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Business profile answers collected before KYB verification (shipping
// companies only). Same flexible JSON storage as InvestmentProfile.
model BusinessProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  answers   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Collateral — links a shipping company's RWA offering to its legal
// documents. One collateral record per on-chain RWA token. The `rwaId`
// matches the `token_id` / `rwa_id` used on-chain by the factory contract.
model Collateral {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  rwaId          String               @unique
  tokenAddress   String?
  status         CollateralStatus     @default(DRAFT)
  collateralData Json
  documents      CollateralDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([rwaId])
  @@index([status])
}

// Individual uploaded files attached to a collateral record.
model CollateralDocument {
  id           String       @id @default(cuid())
  collateralId String
  collateral   Collateral   @relation(fields: [collateralId], references: [id])
  documentType DocumentType
  gcsUri       String
  gcsKey       String
  fileName     String
  mimeType     String
  fileHash     String
  fileSize     Int

  createdAt DateTime @default(now())

  @@index([collateralId])
  @@index([documentType])
}

// On-chain event log — populated by the EventsService polling loop.
model TransactionEvent {
  id              String               @id @default(cuid())
  rwaId           String
  eventType       TransactionEventType
  investorAddress String?
  amount          String?
  txHash          String
  ledger          Int

  createdAt DateTime @default(now())

  @@index([rwaId])
  @@index([eventType])
  @@index([investorAddress])
}

// Cursor for the event listener — the last processed ledger so the
// polling loop can resume after restart without missing events.
model EventListenerCursor {
  id          String   @id @default(cuid())
  contractId  String   @unique
  lastLedger  Int      @default(0)
  lastEventId String?
  updatedAt   DateTime @updatedAt
}

enum CollateralStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  ON_CHAIN
}

enum DocumentType {
  COMMERCIAL_INVOICE
  BILL_OF_LADING
  PROOF_OF_DELIVERY
  SHIPPING_CONTRACT
  NOTICE_OF_ASSIGNMENT
}

enum TransactionEventType {
  RWA_CREATED
  SHARES_BOUGHT
  FUND_COLLECTED
  DEBT_SETTLED
  CLAIMED
}
