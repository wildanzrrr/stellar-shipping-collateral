// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  INVESTOR
  SHIPPING_COMPANY
}

// KYC verification status — sourced from Sumsub webhook events.
enum KycStatus {
  NOT_STARTED // no applicant created yet
  INIT // applicant created, verification not started
  PENDING // documents uploaded, awaiting review
  COMPLETED // verification passed (reviewAnswer = GREEN)
  REJECTED // verification failed / resubmission requested (reviewAnswer = RED)
  ON_HOLD // review paused
}

// Investment profile answers collected before KYC verification.
// Each user has at most one profile (1:1). Answers are stored as JSON
// because the questionnaire structure is flexible (single + multi-select).
model User {
  id                String             @id @default(cuid())
  username          String             @unique
  email             String             @unique
  firstName         String?
  lastName          String?
  role              UserRole           @default(INVESTOR)
  dfnsUserId        String?            @unique
  userAuthToken     String?
  // SHA-256 hash of the currently-valid refresh token (rotation / revocation).
  refreshTokenHash  String?
  wallet            Wallet?
  signSession       SignSession[]
  investmentProfile InvestmentProfile?

  // --- KYC (Sumsub) ---
  // New users are NOT verified regardless of role. This is only set to
  // COMPLETED once Sumsub's applicantReviewed webhook confirms reviewAnswer
  // GREEN. Gates access to the full app until KYC is done.
  kycStatus            KycStatus @default(NOT_STARTED)
  sumsubApplicantId    String?   @unique
  sumsubExternalUserId String? // mirrors our user id for Sumsub lookups

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([username])
  @@index([email])
  @@index([dfnsUserId])
  @@index([kycStatus])
}

model Wallet {
  id           String        @id @default(cuid())
  dfnsWalletId String        @unique
  address      String        @unique
  network      String
  name         String
  signingKeyId String?
  user         User          @relation(fields: [userId], references: [id])
  userId       String        @unique
  signSessions SignSession[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([address])
  @@index([dfnsWalletId])
  @@index([userId])
}

model SignSession {
  id             String  @id @default(cuid())
  message        String
  transactionXdr String
  status         String  @default("initiated")
  signedXdr      String?
  wallet         Wallet  @relation(fields: [walletId], references: [id])
  walletId       String
  user           User    @relation(fields: [userId], references: [id])
  userId         String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([walletId])
  @@index([userId])
  @@index([status])
}

// Investment profile answers collected before KYC verification.
// Each user has at most one profile (1:1). Answers are stored as JSON
// because the questionnaire structure is flexible (single + multi-select).
model InvestmentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  answers   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
