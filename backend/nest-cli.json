{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "config/**/*",
        "outDir": "dist"
      },
      {
        "include": "packages/identity_verifier/dist/**/*",
        "outDir": "dist/src"
      }
    ],
    "watchAssets": true
  }
}